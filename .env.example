# Copy to .env and fill in. NEVER commit .env.
# The dry-run pipeline needs NONE of these — they're only for live runs.

# --- X / Twitter API (pay-per-use). User-context OAuth 2.0. ---
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_USER_ID=

# --- LLM for commentary + scoring ---
# Pick ONE provider (all OpenAI-compatible except Anthropic). Set llm.provider in config.yaml.
GROQ_API_KEY=          # free tier — console.groq.com
GEMINI_API_KEY=        # free tier — aistudio.google.com
XAI_API_KEY=           # paid (Grok) — console.x.ai
XAI_BASE_URL=https://api.x.ai/v1
ANTHROPIC_API_KEY=     # paid (Claude)
# Embeddings (dedup / idea clustering):
OPENAI_API_KEY=

# --- Storage (Turso for remote; local SQLite needs nothing) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Ops ---
REPORT_WEBHOOK=
